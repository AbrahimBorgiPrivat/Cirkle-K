VAR SiteDays =
    CALCULATETABLE (
        SUMMARIZE ( Transactions, TRANSACTIONS[site_number], Transactions[trn_transaction_date] ),
        ALL ( SITE_MASTER )
    )
VAR WithTotals =
    ADDCOLUMNS ( SiteDays, "__v", [SM (B)] )   -- measure respects SiteA, ignores SiteB
VAR WithNZ = FILTER ( WithTotals, NOT ISBLANK ( [__v] ) )
RETURN
    STDEVX.S ( WithNZ, [__v] )
