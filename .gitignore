# Ignore PBI temporary files
**/.pbi/localSettings.json
**/.pbi/cache.abf

# Ignore DATAFORDELER JSON files 
resource/json/datafordeler/*.json


# Ignore environment and cache files
.env
.venv
**/__pycache__**
logs/
systemd/pid

# Ignore editor and session-specific files
.vscode
nohup.out

# Ignore local build output for the shared Tabular Editor helper library
source/workspaces/TabularEditorCLITool/bin/
source/workspaces/TabularEditorCLITool/obj/
